# Copy this file to .env and fill in your values
#   Windows:  copy .env.example .env
#   Mac/Linux: cp .env.example .env

# ── Anthropic API (used by Claude Terminal in dashboard) ───────────────────
ANTHROPIC_API_KEY=

# ── Dashboard default member ───────────────────────────────────────────────
DEFAULT_MEMBER_USERNAME=

# ── Staging ────────────────────────────────────────────────────────────────
STAGING_PLAYER_USERNAME=
STAGING_PLAYER_PASSWORD=
STAGING_BO_USERNAME=
STAGING_BO_PASSWORD=
STAGING_BO_2FA_SECRET=

# ── UAT ────────────────────────────────────────────────────────────────────
UAT_PLAYER_USERNAME=
UAT_PLAYER_PASSWORD=
UAT_BO_USERNAME=
UAT_BO_PASSWORD=
UAT_BO_2FA_SECRET=

# ── Production ─────────────────────────────────────────────────────────────
PROD_PLAYER_USERNAME=
PROD_PLAYER_PASSWORD=
PROD_BO_USERNAME=
PROD_BO_PASSWORD=
PROD_BO_2FA_SECRET=

# ── Member Setup (CreateMemberAndSaveSession) ──────────────────────────────
MEMBER_INITIAL_PASSWORD=
MEMBER_NEW_PASSWORD=
MEMBER_BANK_CODE=

# ── Deposit / Withdrawal defaults (optional — tests have built-in fallbacks) ─
DEPOSIT_BANK_NAME=
DEPOSIT_PACKAGE_NAME=
DEPOSIT_ROLLOVER_MULTIPLIER=
